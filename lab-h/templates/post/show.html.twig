{% extends 'base.html.twig' %}

{% block title %}Post{% endblock %}

{% block body %}
    <h1 class="page-heading">Szczegóły postu</h1>

    <div class="bg-white border rounded shadow-sm p-3 mb-3">
        <table class="table table-bordered detail-table mb-0">
            <tbody>
                <tr>
                    <th>Id</th>
                    <td>{{ post.id }}</td>
                </tr>
                <tr>
                    <th>Temat</th>
                    <td>{{ post.subject }}</td>
                </tr>
                <tr>
                    <th>Treść</th>
                    <td>{{ post.content }}</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-outline-secondary" href="{{ path('app_post_index') }}">Powrót do listy</a>
        <a class="btn btn-brand" href="{{ path('app_post_edit', {'id': post.id}) }}">Edytuj</a>
        {{ include('post/_delete_form.html.twig') }}
    </div>
{% endblock %}
