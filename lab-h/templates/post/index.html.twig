{% extends 'base.html.twig' %}

{% block title %}Lista postów{% endblock %}

{% block body %}
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
        <h1 class="page-heading mb-0">Lista postów</h1>
        <a class="btn btn-brand" href="{{ path('app_post_new') }}">Dodaj nową</a>
    </div>

    <div class="table-responsive bg-white border rounded shadow-sm p-2">
        <table class="table table-bordered align-middle post-table mb-0">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Temat</th>
                    <th>Treść</th>
                    <th>Akcje</th>
                </tr>
            </thead>
            <tbody>
            {% for post in posts %}
                <tr>
                    <td>{{ post.id }}</td>
                    <td>{{ post.subject }}</td>
                    <td>{{ post.content }}</td>
                    <td class="text-nowrap">
                        <a class="btn btn-sm btn-outline-danger" href="{{ path('app_post_show', {'id': post.id}) }}">Pokaż</a>
                        <a class="btn btn-sm btn-outline-secondary" href="{{ path('app_post_edit', {'id': post.id}) }}">Edytuj</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="text-center text-muted">Brak rekordów</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
